---
import { SITE, FEATURES } from '@/config';
import Head from '@components/Head.astro';
import Sidebar from '@components/Sidebar.astro';
import Topbar from '@components/Topbar.astro';
import Footer from '@components/Footer.astro';
import SearchResults from '@components/SearchResults.astro';
import UpdateList from '@components/UpdateList.astro';
import TrendingTags from '@components/TrendingTags.astro';
import { getPostUrl } from '@/utils/slug';
import { getExcerpt } from '@/utils/text';
import type { CollectionEntry } from 'astro:content';
import '@styles/main.bundle.scss';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  panelIncludes?: string[];
  tailIncludes?: string[];
  refactorContent?: boolean;
  math?: boolean;
  mermaid?: boolean;
  olderPost?: CollectionEntry<'posts'> | null;
  newerPost?: CollectionEntry<'posts'> | null;
  relatedPosts?: CollectionEntry<'posts'>[];
}

const {
  title,
  description,
  image,
  lang = SITE.lang,
  panelIncludes = [],
  tailIncludes = [],
  refactorContent: _refactorContent = false,
  math = false,
  mermaid = false,
  olderPost,
  newerPost,
  relatedPosts = []
} = Astro.props;

// Helper function to format date
const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString(lang, {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};

---

<!doctype html>
<html lang={lang} data-mode={FEATURES.theme_mode || undefined}>
  <Head
    title={title}
    description={description}
    image={image}
    math={math}
    mermaid={mermaid}
  />

  <body>
    <Sidebar lang={lang} />

    <div id="main-wrapper" class="d-flex justify-content-center">
      <div class="container d-flex flex-column px-xxl-5">
        <Topbar lang={lang} />

        <div class="row flex-grow-1">
          <main aria-label="Main Content" class="col-12 col-lg-11 col-xl-9 px-md-4">
            <slot />
          </main>

          <!-- panel -->
          <aside aria-label="Panel" id="panel-wrapper" class="col-xl-3 ps-2 text-muted">
            <div class="access">
              <UpdateList lang={lang} />
              <TrendingTags lang={lang} />
            </div>

            {panelIncludes.includes('toc') && (
              <>
                <div class="toc-border-cover z-3"></div>
                <section id="toc-wrapper" class="invisible position-sticky ps-0 pe-4 pb-4">
                  <h2 class="panel-heading ps-3 pb-2 mb-0">Contents</h2>
                  <nav id="toc"></nav>
                </section>
              </>
            )}
          </aside>
        </div>

        <div class="row">
          <!-- tail -->
          <div id="tail-wrapper" class="col-12 col-lg-11 col-xl-9 px-md-4">
            {tailIncludes.includes('related-posts') && relatedPosts.length > 0 && (
              <aside id="related-posts" aria-labelledby="related-label">
                <h3 class="mb-4" id="related-label">Further Reading</h3>
                <nav class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-4">
                  {relatedPosts.map((post) => (
                    <article class="col">
                      <a href={getPostUrl(post.slug)} class="post-preview card h-100">
                        <div class="card-body">
                          <time>{formatDate(post.data.date)}</time>
                          <h4 class="pt-0 my-2">{post.data.title}</h4>
                          <div class="text-muted">
                            <p>{post.data.description || getExcerpt(post.body, 150)}</p>
                          </div>
                        </div>
                      </a>
                    </article>
                  ))}
                </nav>
              </aside>
            )}

            {tailIncludes.includes('post-nav') && (
              <nav class="post-navigation d-flex justify-content-between" aria-label="Post Navigation">
                {olderPost ? (
                  <a href={getPostUrl(olderPost.slug)} class="btn btn-outline-primary" aria-label="Older" rel="prev">
                    <p>{olderPost.data.title}</p>
                  </a>
                ) : (
                  <a href="#" class="btn btn-outline-primary disabled" aria-label="Older">
                    <p>Older Post</p>
                  </a>
                )}
                {newerPost ? (
                  <a href={getPostUrl(newerPost.slug)} class="btn btn-outline-primary" aria-label="Newer" rel="next">
                    <p>{newerPost.data.title}</p>
                  </a>
                ) : (
                  <a href="#" class="btn btn-outline-primary disabled" aria-label="Newer">
                    <p>Newer Post</p>
                  </a>
                )}
              </nav>
            )}

            {tailIncludes.includes('comments') && (
              <div id="comments" class="mt-5">
                <!-- Comments section placeholder -->
              </div>
            )}

            <Footer lang={lang} />
          </div>
        </div>

        <SearchResults lang={lang} />
      </div>

      <aside aria-label="Scroll to Top">
        <button id="back-to-top" type="button" class="btn btn-lg btn-box-shadow">
          <i class="fas fa-angle-up"></i>
        </button>
      </aside>
    </div>

    <div id="mask" class="d-none position-fixed w-100 h-100 z-1"></div>

    {FEATURES.pwa.enabled && (
      <!-- PWA notification will be added later -->
      <div id="notification"></div>
    )}

    <!-- Scripts will be added in Head component -->
  </body>
</html>
