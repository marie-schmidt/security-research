---
import BaseLayout from '@layouts/BaseLayout.astro';
import {
  getAllCategories,
  getPostsBySubCategory,
  getSubCategoryName,
} from '@/utils/taxonomy';
import { getPostUrl } from '@/utils/slug';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  const paths = [];

  for (const [parentSlug, category] of categories) {
    for (const [subSlug] of category.subCategories) {
      const subCategoryName = await getSubCategoryName(parentSlug, subSlug);
      paths.push({
        params: { parent: parentSlug, subcategory: subSlug },
        props: {
          parentSlug,
          subSlug,
          categoryName: category.name,
          subCategoryName,
        },
      });
    }
  }

  return paths;
}

const { parentSlug, subSlug, categoryName, subCategoryName } = Astro.props;
const posts = await getPostsBySubCategory(parentSlug, subSlug);

// Format date for display
function formatDate(date: Date): { day: string; month: string; year: number } {
  return {
    day: date.getDate().toString().padStart(2, '0'),
    month: date.toLocaleDateString('en-US', { month: 'short' }),
    year: date.getFullYear(),
  };
}
---

<BaseLayout title={`Category: ${categoryName} / ${subCategoryName}`}>
  <article class="px-1">
    <div id="page-category">
      <h1 class="ps-lg-2">
        <i class="far fa-folder-open fa-fw text-muted"></i>
        <a href={`/categories/${parentSlug}/`} class="text-muted">{categoryName}</a>
        <span class="text-muted"> / </span>
        {subCategoryName}
        <span class="lead text-muted ps-2">{posts.length}</span>
      </h1>
      <ul class="content ps-0">
        {
          posts.map(post => {
            const postUrl = getPostUrl(post.slug);
            const { day, month, year } = formatDate(post.data.date);

            return (
              <li class="d-flex justify-content-between px-md-3">
                <a href={postUrl}>{post.data.title}</a>
                <span class="dash flex-grow-1" />
                <span class="text-muted small text-nowrap">
                  {month} {day}
                  {post.data.date.getFullYear() !== new Date().getFullYear() && `, ${year}`}
                </span>
              </li>
            );
          })
        }
      </ul>
    </div>
  </article>
</BaseLayout>
