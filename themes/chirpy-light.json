{
  "name": "Chirpy Light",
  "type": "light",
  "colors": {
    "editor.background": "#f6f8fa",
    "editor.foreground": "#24292f"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#68717a"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#cf222e"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.namespace",
        "support.class",
        "support.type",
        "variable.language"
      ],
      "settings": {
        "foreground": "#953800"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.template",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#0a3069"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.language",
        "keyword.operator",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8250df"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute",
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#116329"
      }
    },
    {
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": {
        "foreground": "#116329"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#0550ae"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#24292f"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "punctuation.separator"],
      "settings": {
        "foreground": "#24292f"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#f6f8fa",
        "background": "#82071e"
      }
    },
    {
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": {
        "foreground": "#116329",
        "background": "#dafbe1"
      }
    },
    {
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": {
        "foreground": "#82071e",
        "background": "#ffebe9"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#0550ae",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#24292f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#24292f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#8250df"
      }
    }
  ]
}
